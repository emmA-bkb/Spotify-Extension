{
  "manifest_version": 3,
  "name": "Spoti Extension",
  "version": "1.0.0",
  "description": "Controle seu Spotify com facilidade",
  "permissions": [
    "storage",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*",
    "https://accounts.spotify.com/*",
    "https://api.spotify.com/*",
    "https://spotify-extencao.onrender.com/*"
  ],
  "background": {
    "scripts": ["src/config.js", "background/background.js"]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Spoti Extension"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "spoti-extension@firefox.example.com"
    }
  }
}